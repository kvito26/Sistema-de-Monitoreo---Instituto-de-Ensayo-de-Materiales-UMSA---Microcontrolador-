//programa para el envio de datos de temperatura y humedad hacia el servidor websocket
#include <WiFi.h>
#include <WebSocketsClient.h>
#include <ArduinoJson.h>
#include <DHT.h>

//definiendo los pines para el sensor de temp y hum
#define DHTTYPE DHT22
#define DHTPIN 4

DHT dht(DHTPIN, DHTTYPE, 22);
int led = 12;
int led2 = 14;
int led3 = 27;

//estados de los pines
bool estado_led = 0;
bool estado_led2 = 0;
bool estado_led3 = 0;

//configurando la conexion a wifi
const char* ssid = "vw-03826";
const char* password = "ZTERRTHJ8902852";

//configuracion para la direccion del servidor websocket
const char* ws_host = "192.168.1.224";
const int ws_port = 8080;

//creando al objeto websocket que guarda la conexion entre el servidor WebSocket
WebSocketsClient webSocket;

//identificador unico para este dispostivo esp32
const String DEVICE_ID = "esp_amb1";

bool conexion_server = false;

//Variable para controlar el PWM del ventilador
volatile bool activar_pwm = false;
volatile bool desactivar_pwm = false;

//Declaración de funciones
void webSocketEvent(WStype_t type, uint8_t * payload, size_t length);
void envioDatosTH();
void envioFeedbackVent(int nuevoEstado);
void envioFeedbackCalent(int nuevoEstado);
void envioFeedbackHumi(int nuevoEstado);
void envioAutenticacion();
void incrementarVel();
void decrementarVel();

// ========== TAREAS DE FreeRTOS ==========

// Tarea 1: Mantener la conexión WebSocket
void tareaWebSocket(void *parameter) {
    for(;;) {
        webSocket.loop();
        vTaskDelay(10 / portTICK_PERIOD_MS);
    }
}

// Tarea 2: Enviar datos de temperatura y humedad cada 5 segundos
void tareaEnvioDatos(void *parameter) {
    for(;;) {
        if (conexion_server == true) {
            envioDatosTH();
        }
        vTaskDelay(5000 / portTICK_PERIOD_MS);
    }
}

// Tarea 3: Enviar feedback de los LEDs cada 500ms
void tareaFeedback(void *parameter) {
    for(;;) {
        if (conexion_server == true) {
            envioFeedbackVent(estado_led);
            envioFeedbackCalent(estado_led2);
            envioFeedbackHumi(estado_led3);
        }
        vTaskDelay(500 / portTICK_PERIOD_MS);
    }
}

// Tarea 4: Control PWM del ventilador
void tareaPWM(void *parameter) {
    for(;;) {
        // Si se recibe orden de activar ventilador
        if (activar_pwm) {
            activar_pwm = false;
            incrementarVel();
        }
        
        // Si se recibe orden de desactivar ventilador
        if (desactivar_pwm) {
            desactivar_pwm = false;
            decrementarVel();
        }
        
        vTaskDelay(50 / portTICK_PERIOD_MS);
    }
}

// ========== SETUP ==========
void setup() {
    Serial.begin(115200);
    dht.begin();

    //el modo de los pines
    pinMode(led, OUTPUT);
    digitalWrite(led, estado_led);
    pinMode(led2, OUTPUT);
    digitalWrite(led2, estado_led2);
    pinMode(led3, OUTPUT);
    digitalWrite(led3, estado_led3);

    //conectando a wifi
    WiFi.begin(ssid, password);
    while (WiFi.status() != WL_CONNECTED){
        delay(500);
        Serial.print(".");
    }
    Serial.println("\nSe ha conectado a la red WiFi");

    //configurando el websocket cliente
    webSocket.begin(ws_host, ws_port, "/");
    webSocket.onEvent(webSocketEvent);
    webSocket.setReconnectInterval(5000);

    // ========== CREACIÓN DE TAREAS FreeRTOS ==========
    
    // Tarea WebSocket (prioridad 2, núcleo 0)
    xTaskCreatePinnedToCore(
        tareaWebSocket,
        "WebSocketTask",
        4096,
        NULL,
        2,
        NULL,
        0
    );

    // Tarea envío de datos (prioridad 1, núcleo 1)
    xTaskCreatePinnedToCore(
        tareaEnvioDatos,
        "EnvioDatosTask",
        4096,
        NULL,
        1,
        NULL,
        1
    );

    // Tarea feedback (prioridad 1, núcleo 1)
    xTaskCreatePinnedToCore(
        tareaFeedback,
        "FeedbackTask",
        4096,

        NULL,
        1,
        NULL,
        1
    );

    // Tarea PWM del ventilador (prioridad 3, núcleo 0) - ALTA PRIORIDAD
    xTaskCreatePinnedToCore(
        tareaPWM,
        "PWMTask",
        2048,
        NULL,
        3,
        NULL,
        0
    );

    Serial.println("Tareas FreeRTOS creadas exitosamente");
}

// ========== LOOP ==========
void loop() {
    // El loop() queda vacío porque las tareas se ejecutan en paralelo
    vTaskDelay(1000 / portTICK_PERIOD_MS);
}`

// ========== FUNCIONES AUXILIARES ==========

void webSocketEvent(WStype_t type, uint8_t * payload, size_t length){
    switch(type){
        case WStype_DISCONNECTED:
            Serial.println("[WS] Desconectado del servidor");
            conexion_server = false;
            break;

        case WStype_CONNECTED:
            Serial.println("[WS] Conectado con el servidor");
            Serial.println("\tEnviando llave de autenticacion...");
            envioAutenticacion();
            conexion_server = true;
            break;

        case WStype_TEXT:
            Serial.printf("[WS] Mensaje recibido: %s\n", payload);

            JsonDocument mensaje_rec;
            DeserializationError error = deserializeJson(mensaje_rec, payload);
            
            if (error){
                Serial.print("Error al parsear JSON: ");
                Serial.println(error.c_str());
                return;
            }
            
            bool valor = 0;
            
            // Control PWM del ventilador
            if (mensaje_rec["tipo"] == "ordenVent1"){
                valor = (bool) mensaje_rec["valor"];
                activar_pwm = true;  // Señal para la tarea PWM
                estado_led = valor;
                envioFeedbackVent(valor);
            }
            else if (mensaje_rec["tipo"] == "ordenVent0"){
                valor = (bool) mensaje_rec["valor"];
                desactivar_pwm = true;  // Señal para la tarea PWM
                estado_led = valor;
                envioFeedbackVent(valor);
            }
            // Control calentador
            else if (mensaje_rec["tipo"] == "ordenCalent"){
                valor = (bool) mensaje_rec["valor"];
                digitalWrite(led2, valor);
                envioFeedbackCalent(valor);
                estado_led2 = valor;
            }
            // Control humidificador
            else if (mensaje_rec["tipo"] == "ordenHumi"){
                valor = (bool) mensaje_rec["valor"];
                digitalWrite(led3, valor);
                envioFeedbackHumi(valor);
                estado_led3 = valor;
            }
            break;
    }
}

void envioAutenticacion(){
    JsonDocument auth;
    auth["action"] = "autenticacion";
    auth["id_disp"] = DEVICE_ID;

    String mensaje;
    serializeJson(auth, mensaje);
    webSocket.sendTXT(mensaje);
}

void envioFeedbackVent(int nuevoEstado){
    JsonDocument feedback;
    feedback["action"] = "feedbackVent";
    feedback["id_disp"] = DEVICE_ID;
    feedback["estado_ahora"] = nuevoEstado;	

    String mensaje;
    serializeJson(feedback, mensaje);
    webSocket.sendTXT(mensaje);
}

void envioFeedbackCalent(int nuevoEstado){
    JsonDocument feedback;
    feedback["action"] = "feedbackCalent";
    feedback["id_disp"] = DEVICE_ID;
    feedback["estado_ahora"] = nuevoEstado;	

    String mensaje;
    serializeJson(feedback, mensaje);
    webSocket.sendTXT(mensaje);
}

void envioFeedbackHumi(int nuevoEstado){
    JsonDocument feedback;
    feedback["action"] = "feedbackHumi";
    feedback["id_disp"] = DEVICE_ID;
    feedback["estado_ahora"] = nuevoEstado;	

    String mensaje;
    serializeJson(feedback, mensaje);
    webSocket.sendTXT(mensaje);
}

void envioDatosTH(){
    float temp = dht.readTemperature();
    float hum = dht.readHumidity();

    Serial.println("\nSe envian los datos de temp y hum:");
    Serial.print("\tTemperatura: ");
    Serial.println(temp);
    Serial.print("\tHumedad: ");
    Serial.println(hum);
    
    JsonDocument datos;
    datos["action"] = "datos_TH";
    datos["id_disp"] = DEVICE_ID;
    datos["temp"] = temp;
    datos["hum"] = hum;

    String datos_out;
    serializeJson(datos, datos_out);
    webSocket.sendTXT(datos_out);
    Serial.println("Datos TH enviados exitosamente");
}

// Función para incrementar PWM del ventilador (0 a 255)
void incrementarVel(){
    for(int dutyCycle = 0; dutyCycle <= 255; dutyCycle++){
        analogWrite(led, dutyCycle);
        vTaskDelay(20 / portTICK_PERIOD_MS);  // Usar vTaskDelay en vez de delay
    }
}

// Función para decrementar PWM del ventilador (255 a 0)
void decrementarVel(){
    for(int dutyCycle = 255; dutyCycle >= 0; dutyCycle--){
        analogWrite(led, dutyCycle);
        vTaskDelay(20 / portTICK_PERIOD_MS);  // Usar vTaskDelay en vez de delay
    }
}
